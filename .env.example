# API server (artifacts/api-server) — local dev only; Vercel uses api/index.ts
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Crypto dashboard (artifacts/crypto-dashboard)
# PORT=5173 (optional; defaults for Vite build)
# BASE_PATH=/ (optional; defaults to /)
# API_PROXY_TARGET=http://127.0.0.1:5000

# Vercel frontend (only when API is on a different host than the UI)
# VITE_API_BASE_URL=https://your-api-project.vercel.app

# Vercel (set in project dashboard; build uses PORT=5173 BASE_PATH=/ via build:vercel)
# VERCEL=1 (set automatically on Vercel)

# Database (lib/db) — required only when using Drizzle
# DATABASE_URL=postgresql://user:password@localhost:5432/crypto_market_hub
